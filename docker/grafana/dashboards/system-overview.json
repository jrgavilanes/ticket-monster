{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{
        "expr": "rate(http_server_requests_seconds_count[1m])",
        "legendFormat": "{{uri}} {{method}}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{
        "expr": "rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])",
        "legendFormat": "{{uri}} {{status}}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(http_server_requests_seconds_bucket[1m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket[1m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket[1m]))", "legendFormat": "p99" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Active Reservations",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [{ "expr": "reservations_active", "legendFormat": "Active" }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Reservation Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        { "expr": "rate(reservations_created_total[1m])", "legendFormat": "Created" },
        { "expr": "rate(reservations_expired_total[1m])", "legendFormat": "Expired" },
        { "expr": "rate(reservations_confirmed_total[1m])", "legendFormat": "Confirmed" },
        { "expr": "rate(reservations_cancelled_total[1m])", "legendFormat": "Cancelled" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "JVM Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [{
        "expr": "jvm_memory_used_bytes{area=\"heap\"}",
        "legendFormat": "{{id}}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "HikariCP Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [{
        "expr": "hikaricp_connections_active",
        "legendFormat": "active"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "schemaVersion": 39,
  "tags": ["ticket-monster"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Ticket Monster - System Overview",
  "uid": "ticket-monster-overview"
}
